{
  "name": "vfx-audio-manager",
  "version": "1.0.0",
  "description": "现代化桌面音效管理软件 - 为视频剪辑创作者打造",
  "main": "dist/electron/main.js",
  "author": "Richard29",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,electron \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "set VFX_DEV=true && npm run build:electron && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "pack": "electron-builder --win --config electron-builder.yml",
    "dist": "npm run build && npm run pack",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "music-metadata": "^11.12.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "uuid": "^10.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "keywords": []
}
